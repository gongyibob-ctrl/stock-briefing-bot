# ===================================
# stock-briefing 环境变量模板
# 复制为 .env 并填入真实值
# ===================================

# ---- LLM (必填) ----
# 推荐 DeepSeek（性价比高）；其他兼容 OpenAI 协议的源也行
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek/deepseek-v4-pro

# ---- 飞书自定义机器人 webhook (必填，brief.py 推送用) ----
# 群里 -> 群机器人 -> 自定义机器人 -> 复制 webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---- 飞书应用机器人 (推荐，bot.py + brief.py 推送都用它) ----
# https://open.feishu.cn 创建自建应用 + 申请 im:message + im:message.group_at_msg 权限 + 启用长连接
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# brief 推送目标群（从 bot.log 看到 @ 消息的 chat_id 拿，形如 oc_xxxxxxxxx）
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
